            color: #fff;
            padding: 2rem 1rem;
            text-align: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .container {
            max-width: 800px;
            margin: 2rem auto;
            padding: 0 1rem;
        }

        .card {
            background: #fff;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            margin-bottom: 1.5rem;
        }

        h1 { margin: 0; font-size: 2.5rem; }
        h2 { color: var(--accent-color); border-bottom: 2px solid #eee; padding-bottom: 0.5rem; }

        .info-list {
            list-style: none;
            padding: 0;
        }

        .info-list li {
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
        }

        .info-list strong {
            width: 100px;
            color: var(--primary-color);
        }

        .contact-link {
            color: var(--accent-color);
            text-decoration: none;
        }

        .contact-link:hover {
            text-decoration: underline;
        }

        footer {
            text-align: center;
            padding: 2rem;
            font-size: 0.9rem;
            color: #777;
        }

        /* 響應式優化 */
        @media (max-width: 600px) {
            h1 { font-size: 1.8rem; }
            .info-list li { flex-direction: column; align-items: flex-start; }
        }
    </style>
</head>
